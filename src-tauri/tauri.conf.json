{
  "build": {
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/chrultrabook-tools/browser",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "msi", "nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["chromium-ectool", "chromium-cbmem"],
        "files": {
          "linux/chrultrabook-tools-root": "/usr/bin/chrultrabook-tools-root",
          "linux/com.chrultrabook.tools.policy": "/usr/share/polkit-1/actions/com.chrultrabook.tools.policy",
          "linux/chrultrabook-tools.desktop": "/usr/share/applications/chrultrabook-tools.desktop"
        }
      },
      "rpm": {
        "depends": ["coreboot-utils-cbmem", "chromium-ectool"],
        "files": {
          "linux/chrultrabook-tools-root": "/usr/bin/chrultrabook-tools-root",
          "linux/com.chrultrabook.tools.policy": "/usr/share/polkit-1/actions/com.chrultrabook.tools.policy",
          "linux/chrultrabook-tools.desktop": "/usr/share/applications/chrultrabook-tools.desktop"
        }
      }
    }
  },
  "productName": "chrultrabook-tools",
  "version": "3.1.2",
  "identifier": "com.chrultrabook.tools",
  "plugins": {},
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Chrultrabook Tools",
        "width": 430,
        "height": 480,
        "maximizable": true,
        "resizable": true,
        "theme": "Dark"
      }
    ]
  }
}
